{
    "id": "collector",
    "realm": "collector",
    "enabled": true,
    "roles": {
        "realm": [
            {
                "name": "seller",
                "description": "Seller Role"
            },
            {
                "name": "admin",
                "description": "Admin Role"
            }
        ]
    },
    "users": [],
    "clients": [
        {
            "clientId": "collector-web",
            "enabled": true,
            "publicClient": true,
            "directAccessGrantsEnabled": true,
            "redirectUris": [
                "https://collector-shop.com/*"
            ],
            "webOrigins": [
                "https://collector-shop.com"
            ]
        },
        {
            "clientId": "collector-api",
            "enabled": true,
            "publicClient": false,
            "secret": "${COLLECTOR_API_SECRET}",
            "directAccessGrantsEnabled": true,
            "serviceAccountsEnabled": true,
            "redirectUris": [
                "https://api.collector-shop.com/*"
            ]
        }
    ]
}