{
  "name": "collector-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Collector project monorepo",
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "lint": "npm run lint --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "scan": "npm audit && npm run scan --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "local:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "local:down": "docker compose -f infra/local/docker-compose.yml down",
    "prepare": "husky"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "prettier": "^3.0.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2"
  }
}