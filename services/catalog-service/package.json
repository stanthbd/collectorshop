{
    "name": "catalog-service",
    "version": "1.0.0",
    "description": "Node.js API for the catalog",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "npx prisma migrate deploy && node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "npx prisma generate && tsc",
        "lint": "eslint src/",
        "test:unit": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js tests/unit",
        "test:integration": "jest tests/*.integration.spec.ts",
        "scan": "npm audit"
    },
    "dependencies": {
        "@prisma/client": "^5.14.0",
        "amqplib": "^0.10.9",
        "dotenv": "^17.3.1",
        "express": "^4.19.2",
        "express-async-errors": "^3.1.1",
        "jsonwebtoken": "^9.0.3",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.8",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.14",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^20.12.7",
        "@types/supertest": "^7.2.0",
        "jest": "^29.7.0",
        "prisma": "^5.14.0",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "tsx": "^4.7.2",
        "typescript": "^5.4.5"
    }
}