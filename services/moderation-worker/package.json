{
    "name": "moderation-worker",
    "version": "1.0.0",
    "description": "RabbitMQ worker for moderation",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "lint": "eslint src/",
        "test:unit": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
        "scan": "npm audit"
    },
    "dependencies": {
        "amqplib": "^0.10.4",
        "express": "^4.19.2",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.5",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.12.7",
        "jest": "^29.7.0",
        "ts-jest": "^29.1.2",
        "tsx": "^4.7.2",
        "typescript": "^5.4.5"
    }
}